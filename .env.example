# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only. Uitsluitend voor de reminder-taak (nooit in de browser!).
# Te vinden in Supabase → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Twilio WhatsApp ───────────────────────────────────────
# Twilio Console → Account Info.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Afzendernummer. Sandbox: whatsapp:+14155238886
# Productie: whatsapp:+31XXXXXXXXX (jullie goedgekeurde nummer)
TWILIO_WHATSAPP_FROM=
# Optioneel: SID van het goedgekeurde WhatsApp-sjabloon (productie).
# Leeg laten tijdens sandbox-testen (dan wordt vrije tekst gebruikt).
TWILIO_CONTENT_SID=

# ── Reminders ─────────────────────────────────────────────
# Hoeveel minuten vóór de afspraak de WhatsApp verstuurd wordt.
REMINDER_OFFSET_MINUTES=30
# Willekeurig geheim; beschermt /api/reminders tegen misbruik.
# Zet dezelfde waarde in Vercel én in je cron-configuratie.
CRON_SECRET=
